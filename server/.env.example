# Copy this file to .env and fill in your real values.
# Never commit the real .env file — it's already in .gitignore.

# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── AWS / DynamoDB ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=lifeos-prod

# ── Anthropic Claude API ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string

# ── Google OAuth (for sign-in + Calendar/Gmail integration) ─
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── OAuth callback base URL (used for integrations) ─────
OAUTH_REDIRECT_BASE=http://localhost:4000/api
